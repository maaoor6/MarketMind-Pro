      "Bash(docker compose:*)",
      "Bash(grep -v \"^$\")",
      "Bash(find /Users/maorworko/Desktop/project/MarketMind-Pro/src -name \"*.py\" -exec grep -l \"Ticker\\\\|fundamental\\\\|earnings\\\\|pe_ratio\\\\|eps\\\\|insider\" {} \\\\;)",
      "Bash(find /Users/maorworko/Desktop/project/MarketMind-Pro -name \"*.py\" -type f -exec grep -l \"github\\\\|git push\\\\|deploy\\\\|publish\" {} \\\\;)",
      "Bash(python -c ':*)",
