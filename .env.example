# ══════════════════════════════════════════════════════════════════════
#  MarketMind-Pro Environment Configuration Template
#  Copy to .env and fill in your values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://marketmind:password@localhost:5432/marketmind
DATABASE_URL_SYNC=postgresql+psycopg2://marketmind:password@localhost:5432/marketmind

# ── Cache ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_or_channel_id

# ── External APIs ────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# ── GitHub Pages ─────────────────────────────────────────────────────
GITHUB_PAGES_REPO=maaoor6/MarketMind-Pro
GITHUB_TOKEN=your_github_personal_access_token

# ── MCP Servers ──────────────────────────────────────────────────────
GOOGLE_SEARCH_MCP_PORT=8001
SQL_MCP_PORT=8002
GOOGLE_API_KEY=your_google_custom_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id

# ── App Settings ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE_US=America/New_York
TIMEZONE_TASE=Asia/Jerusalem
